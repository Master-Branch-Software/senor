#!/usr/bin/env bash
# Señor installer — set up rule files for selected AI agents.
# Usage: ./install [--agents LIST] [--scope WHERE] [--auto-update|--no-auto-update]
#                  [--conflict skip|overwrite|append] [-h]

set -euo pipefail

# ---- Constants ----------------------------------------------------------

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
SENOR_SKILL="$SCRIPT_DIR/SKILL.md"
TEMPLATES_DIR="$SCRIPT_DIR/templates"
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/senor"
STATE_FILE="$STATE_DIR/state"

# Agent registry: name|template|project_relpath|home_abspath|display
#
# Why two install modes:
#   - File-mode agents (Cursor, Windsurf, Cline, Copilot, Codex) read a
#     single rule file. We write that file with the absolute path to SKILL.md
#     baked in via __SENOR_SKILL__ substitution. Tiny, fast, no filesystem
#     permissions required.
#   - Directory-mode agents (Claude Code) load the whole skill directory
#     (SKILL.md plus per-domain AGENTS.md plus chapters). We can't fake that
#     with a one-line file, and we don't want to copy ~10MB of guidelines on
#     every update, so we symlink the target back at this checkout. Empty
#     template field = symlink mode (junction on Windows via mklink /J).
#
# Empty home_abspath means the agent has no documented user-global file path
# (Cursor, Copilot) and will be skipped under home scope.
AGENTS=(
  "claude-code||.claude/skills/senor|__HOME__/.claude/skills/senor|Claude Code"
  "cursor|cursor.mdc|.cursor/rules/senor.mdc||Cursor"
  "windsurf|windsurf.md|.windsurf/rules/senor.md|__HOME__/.codeium/windsurf/memories/global_rules.md|Windsurf"
  "cline|cline.md|.clinerules/senor.md|__HOME__/Documents/Cline/Rules/senor.md|Cline"
  "copilot|copilot.md|.github/copilot-instructions.md||GitHub Copilot"
  "codex|codex.md|AGENTS.md|__HOME__/.codex/AGENTS.md|Codex CLI"
  "warp|warp.md|AGENTS.md||Warp"
  "aider|aider.md|CONVENTIONS.md||Aider"
  "gemini|gemini.md|GEMINI.md|__HOME__/.gemini/GEMINI.md|Gemini CLI"
  "continue|continue.md|.continue/rules/senor.md|__HOME__/.continue/rules/senor.md|Continue"
  "zed|zed.md|.rules||Zed"
)
N_AGENTS=${#AGENTS[@]}

# ---- ANSI ---------------------------------------------------------------

ESC=$'\033'
CSI="${ESC}["
BOLD="${CSI}1m"
DIM="${CSI}2m"
RESET="${CSI}0m"
GREEN="${CSI}32m"
RED="${CSI}31m"
YELLOW="${CSI}33m"
CYAN="${CSI}36m"

# Disable colour if stdout isn't a TTY.
if [[ ! -t 1 ]]; then
  BOLD=""; DIM=""; RESET=""; GREEN=""; RED=""; YELLOW=""; CYAN=""
fi

die() { printf '%serror:%s %s\n' "$RED" "$RESET" "$*" >&2; exit 1; }
warn() { printf '%s!%s %s\n' "$YELLOW" "$RESET" "$*"; }
ok() { printf '%s✓%s %s\n' "$GREEN" "$RESET" "$*"; }
note() { printf '%s%s%s\n' "$DIM" "$*" "$RESET"; }

print_banner() {
  # Mascot above "Senor Installer". The bot wears a sombrero, has two
  # glowing eyes, and a curly mustache — same vibes as logo.webp.
  # The /\/ in the text's top row is a stylized Spanish tilde over the n
  # of "Senor".
  printf '%s' "$CYAN"
  cat <<'EOF'
                       _____
                    __/_____\__
                     | o   o |
                     |  vMv  |
                      \_____/

  ___      /\/            ___         _        _ _
 / __| ___ _ _  ___ _ _  |_ _|_ _  __| |_ __ _| | |___ _ _
 \__ \/ -_) ' \/ _ \ '_|  | || ' \(_-<  _/ _` | | / -_) '_|
 |___/\___|_||_\___/_|   |___|_||_/__/\__\__,_|_|_\___|_|
EOF
  printf '%s\n' "$RESET"
}

# ---- Defaults / flags ---------------------------------------------------

SCOPE_KIND=""         # project | home | custom
SCOPE_PATH=""         # used for project (cwd) and custom (user-supplied)
SELECTED_AGENTS=""
AUTO_UPDATE=""        # empty = prompt
UPDATE_FREQUENCY=""     # daily | weekly  (only used when AUTO_UPDATE=yes)
CONFLICT_MODE=""      # empty = prompt per file

show_help() {
  cat <<EOF
${BOLD}Señor installer${RESET}

Usage: ./install [options]

Options:
  --agents LIST       Comma-separated agents (claude-code, cursor, windsurf,
                      cline, copilot, codex, warp, aider, gemini, continue, zed)
  --scope WHERE       project | home | <path>  (default: prompt)
                        project — write to <cwd>/<rel-path> for each agent
                        home    — write to each agent's user-global discovery path
                                  (Cursor and Copilot have no global file path
                                  and will be skipped under this scope)
                        <path>  — same layout as 'project', rooted at <path>
  --auto-update       Install scheduled auto-update task (cron / Task Scheduler)
  --no-auto-update    Skip the auto-update prompt
  --update-frequency X
                      daily | weekly | <N>  (default: weekly. <N> = a positive
                      integer meaning "every N days". Only used with --auto-update)
  --conflict MODE     skip | overwrite | append  (default: prompt per file)
  -h, --help          Show this help

With no flags, runs interactively.
EOF
}

apply_scope_flag() {
  case "$1" in
    project) SCOPE_KIND=project; SCOPE_PATH="$PWD" ;;
    home)    SCOPE_KIND=home;    SCOPE_PATH="" ;;
    *)       SCOPE_KIND=custom;  SCOPE_PATH="$1" ;;
  esac
}

parse_flags() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agents)         SELECTED_AGENTS="$2"; shift 2 ;;
      --scope)          apply_scope_flag "$2"; shift 2 ;;
      --auto-update)    AUTO_UPDATE=yes; shift ;;
      --no-auto-update) AUTO_UPDATE=no; shift ;;
      --update-frequency) UPDATE_FREQUENCY="$2"; shift 2 ;;
      --conflict)       CONFLICT_MODE="$2"; shift 2 ;;
      -h|--help)        show_help; exit 0 ;;
      *)                die "unknown flag: $1" ;;
    esac
  done

  if [[ -n "$CONFLICT_MODE" ]]; then
    case "$CONFLICT_MODE" in
      skip|overwrite|append) ;;
      *) die "invalid --conflict mode: $CONFLICT_MODE" ;;
    esac
  fi
  if [[ -n "$UPDATE_FREQUENCY" ]]; then
    case "$UPDATE_FREQUENCY" in
      daily|weekly) ;;
      *)
        if [[ ! "$UPDATE_FREQUENCY" =~ ^[0-9]+$ ]] || [[ "$UPDATE_FREQUENCY" -le 0 ]]; then
          die "invalid --update-frequency: $UPDATE_FREQUENCY (use 'daily', 'weekly', or a positive number of days)"
        fi
        ;;
    esac
  fi
}

# ---- Agent registry helpers --------------------------------------------

agent_field() {
  local idx="$1" field="$2" line="${AGENTS[$1]}"
  local IFS='|'
  # shellcheck disable=SC2206
  local parts=($line)
  printf '%s' "${parts[$field]}"
}

agent_index_by_name() {
  local name="$1" i
  for ((i=0; i<N_AGENTS; i++)); do
    [[ "$(agent_field "$i" 0)" == "$name" ]] && { printf '%s' "$i"; return 0; }
  done
  return 1
}

# ---- Multi-select TUI ---------------------------------------------------

load_prev_agents() {
  # Read the AGENTS list from the saved state in a subshell so we don't pollute
  # other globals. Sets PREV_AGENTS to a comma-separated list (or empty).
  PREV_AGENTS=""
  [[ -f "$STATE_FILE" ]] || return 0
  # shellcheck disable=SC1090  # state file path is dynamic by design
  PREV_AGENTS="$(. "$STATE_FILE" 2>/dev/null && printf '%s' "${AGENTS:-}")"
}

multiselect() {
  # Sets the global SELECTED_AGENTS to a comma-separated list. Visual output
  # goes to /dev/tty so we don't lose the UI when stdout is piped or captured
  # somewhere up the call stack.
  local -a marked is_installed
  local cursor=0 i drew=0
  local status_msg=""  # set when user tries to continue with nothing selected

  for ((i=0; i<N_AGENTS; i++)); do marked[i]=0; is_installed[i]=0; done

  # Pre-mark agents from the previous install (if any) and tag them as
  # "installed" in the menu so the user can see what's currently set up.
  if [[ -n "${PREV_AGENTS:-}" ]]; then
    local IFS=','
    local -a prev_arr
    read -ra prev_arr <<< "$PREV_AGENTS"
    unset IFS
    local p
    for p in "${prev_arr[@]}"; do
      for ((i=0; i<N_AGENTS; i++)); do
        if [[ "$(agent_field "$i" 0)" == "$p" ]]; then
          marked[i]=1
          is_installed[i]=1
          break
        fi
      done
    done
  fi

  printf '%s' "${CSI}?25l" >/dev/tty  # hide cursor
  # Two traps: EXIT for normal returns (just restore cursor), INT/TERM for
  # signals like Ctrl+C (restore cursor and abort the whole script with 130).
  trap 'printf "%s" "${CSI}?25h" >/dev/tty' EXIT
  trap 'printf "%s" "${CSI}?25h" >/dev/tty; exit 130' INT TERM

  draw() {
    if [[ $drew -eq 1 ]]; then
      printf '%s' "${CSI}$((N_AGENTS + 3))A" >/dev/tty
    fi
    drew=1

    # Header (short — won't wrap on any sensible terminal width).
    printf '%sSelect agents%s%s\n' "$BOLD" "$RESET" "${CSI}K" >/dev/tty

    for ((i=0; i<N_AGENTS; i++)); do
      local mark="[ ]"
      [[ ${marked[$i]} -eq 1 ]] && mark="[${GREEN}x${RESET}]"
      local pre="  "
      [[ $i -eq $cursor ]] && pre="${CYAN}>${RESET} "
      local tag=""
      [[ ${is_installed[$i]} -eq 1 ]] && tag=" ${DIM}(installed)${RESET}"
      printf '%s%s %s%s%s\n' "$pre" "$mark" "$(agent_field "$i" 4)" "$tag" "${CSI}K" >/dev/tty
    done

    if [[ -n "$status_msg" ]]; then
      printf '  %s%s%s%s\n' "$YELLOW" "$status_msg" "$RESET" "${CSI}K" >/dev/tty
    else
      printf '%s\n' "${CSI}K" >/dev/tty
    fi
    # Footer hint on its own line (kept short to avoid line-wrap, which would
    # break the redraw offset above).
    printf '%s↑↓ navigate · space toggle · enter continue · q/ctrl-c abort%s%s\n' \
      "$DIM" "$RESET" "${CSI}K" >/dev/tty
  }

  draw
  while true; do
    local key
    IFS= read -rsn1 key </dev/tty || true
    if [[ "$key" == $'\033' ]]; then
      local rest=""
      IFS= read -rsn2 -t 0.01 rest </dev/tty || true
      key="$key$rest"
    fi
    # Cursor wraps with modular arithmetic (top↑ → bottom, bottom↓ → top).
    case "$key" in
      $'\033[A') cursor=$(( (cursor - 1 + N_AGENTS) % N_AGENTS )); status_msg="" ;;
      $'\033[B') cursor=$(( (cursor + 1) % N_AGENTS ));            status_msg="" ;;
      ' ')       marked[cursor]=$((1 - marked[cursor]));           status_msg="" ;;
      ''|$'\n'|c|C)
        local any=0
        for ((i=0; i<N_AGENTS; i++)); do
          if [[ ${marked[$i]} -eq 1 ]]; then any=1; break; fi
        done
        if [[ $any -eq 1 ]]; then break; fi
        status_msg="Select at least one agent (space to toggle)"
        ;;
      q|Q)       printf '%s' "${CSI}?25h" >/dev/tty; exit 130 ;;
    esac
    draw
  done

  printf '%s' "${CSI}?25h" >/dev/tty
  trap - EXIT INT TERM

  local sel=()
  for ((i=0; i<N_AGENTS; i++)); do
    [[ ${marked[$i]} -eq 1 ]] && sel+=("$(agent_field "$i" 0)")
  done
  SELECTED_AGENTS="$(IFS=,; printf '%s' "${sel[*]}")"
}



# ---- Scope prompt -------------------------------------------------------

single_select() {
  # Generic arrow-driven single-select menu. Sets the global SELECT_INDEX
  # to the chosen option index (0-based).
  # Args:
  #   $1     header text (one line)
  #   $2...  option labels
  local header="$1"; shift
  local labels=("$@")
  local n=${#labels[@]}
  local cursor=0 drew=0 i

  printf '\n' >/dev/tty
  printf '%s' "${CSI}?25l" >/dev/tty
  trap 'printf "%s" "${CSI}?25h" >/dev/tty' EXIT
  trap 'printf "%s" "${CSI}?25h" >/dev/tty; exit 130' INT TERM

  draw() {
    if [[ $drew -eq 1 ]]; then
      printf '%s' "${CSI}$((n + 2))A" >/dev/tty
    fi
    drew=1
    # Header on its own short line so it never wraps.
    printf '%s%s%s%s\n' "$BOLD" "$header" "$RESET" "${CSI}K" >/dev/tty
    for ((i=0; i<n; i++)); do
      if [[ $i -eq $cursor ]]; then
        printf '%s>%s %s%s%s%s\n' "$CYAN" "$RESET" "$BOLD" "${labels[$i]}" "$RESET" "${CSI}K" >/dev/tty
      else
        printf '  %s%s\n' "${labels[$i]}" "${CSI}K" >/dev/tty
      fi
    done
    printf '%s↑↓ navigate · enter select · q/ctrl-c abort%s%s\n' \
      "$DIM" "$RESET" "${CSI}K" >/dev/tty
  }

  draw
  while true; do
    local key
    IFS= read -rsn1 key </dev/tty || true
    if [[ "$key" == $'\033' ]]; then
      local rest=""
      IFS= read -rsn2 -t 0.01 rest </dev/tty || true
      key="$key$rest"
    fi
    # Cursor wraps with modular arithmetic.
    case "$key" in
      $'\033[A') cursor=$(( (cursor - 1 + n) % n )) ;;
      $'\033[B') cursor=$(( (cursor + 1) % n )) ;;
      ''|$'\n')  break ;;
      q|Q)       printf '%s' "${CSI}?25h" >/dev/tty; exit 130 ;;
    esac
    draw
  done

  printf '%s' "${CSI}?25h" >/dev/tty
  trap - EXIT INT TERM
  SELECT_INDEX=$cursor
}

prompt_scope() {
  # Sets SCOPE_KIND and SCOPE_PATH.
  single_select "Where should rule files be installed?" \
    "This project ($PWD)" \
    "User-global (each agent's own discovery path)" \
    "Custom project path"
  case $SELECT_INDEX in
    0) SCOPE_KIND=project; SCOPE_PATH="$PWD" ;;
    1) SCOPE_KIND=home;    SCOPE_PATH="" ;;
    2)
      SCOPE_KIND=custom
      while true; do
        local custom=""
        printf '\n' >/dev/tty
        read -rp "Path: " custom </dev/tty
        if [[ -z "$custom" ]]; then
          warn "Path can't be empty"
          continue
        fi
        # Expand ~ to $HOME (read doesn't do tilde expansion).
        custom="${custom/#\~/$HOME}"
        if [[ ! -d "$custom" ]]; then
          warn "$custom is not a directory"
          continue
        fi
        SCOPE_PATH="$custom"
        break
      done
      ;;
  esac
}

prompt_auto_update() {
  # Sets AUTO_UPDATE.
  single_select "Enable auto-update? (scheduled git pull + reinstall)" \
    "Yes" \
    "No"
  case $SELECT_INDEX in
    0) AUTO_UPDATE=yes ;;
    1) AUTO_UPDATE=no ;;
  esac
}

prompt_frequency() {
  # Sets UPDATE_FREQUENCY to "weekly", "daily", or a positive integer (days).
  single_select "Update frequency?" \
    "Weekly (Sundays, 3am)" \
    "Daily (3am)" \
    "Every N days (custom)"
  case $SELECT_INDEX in
    0) UPDATE_FREQUENCY=weekly ;;
    1) UPDATE_FREQUENCY=daily ;;
    2)
      while true; do
        local n=""
        printf '\n' >/dev/tty
        read -rp "Days between updates: " n </dev/tty
        if [[ "$n" =~ ^[0-9]+$ ]] && [[ "$n" -gt 0 ]]; then
          UPDATE_FREQUENCY="$n"
          break
        fi
        warn "Enter a positive integer"
      done
      ;;
  esac
}

# ---- Conflict prompt ----------------------------------------------------

show_colored_diff() {
  # Print a unified diff with red/green/cyan/bold ANSI coloring. Capped at
  # 80 lines so a giant diff doesn't shove the menu off-screen.
  local target="$1" new_content="$2"
  printf '\n' >/dev/tty
  { diff -u "$target" <(printf '%s' "$new_content") || true; } | head -80 | while IFS= read -r line; do
    case "$line" in
      ---*|+++*) printf '%s%s%s\n' "$BOLD" "$line" "$RESET" >/dev/tty ;;
      +*)        printf '%s%s%s\n' "$GREEN" "$line" "$RESET" >/dev/tty ;;
      -*)        printf '%s%s%s\n' "$RED" "$line" "$RESET" >/dev/tty ;;
      @@*)       printf '%s%s%s\n' "$CYAN" "$line" "$RESET" >/dev/tty ;;
      *)         printf '%s\n' "$line" >/dev/tty ;;
    esac
  done
}

prompt_conflict() {
  # Sets the global CONFLICT_RESULT to skip|overwrite|append.
  local target="$1" new_content="$2"
  CONFLICT_RESULT=""
  printf '\n%s!%s Conflict: %s already exists\n' "$YELLOW" "$RESET" "$target" >/dev/tty
  while true; do
    single_select "What now?" \
      "Skip" \
      "Overwrite" \
      "Append" \
      "Show diff"
    case $SELECT_INDEX in
      0) CONFLICT_RESULT=skip; return ;;
      1) CONFLICT_RESULT=overwrite; return ;;
      2) CONFLICT_RESULT=append; return ;;
      3) show_colored_diff "$target" "$new_content" ;;
    esac
  done
}

# ---- Install one agent --------------------------------------------------

resolve_target_for_agent() {
  # Echoes the absolute target path for a given agent index, or empty if the
  # agent does not support the current scope (caller should warn+skip).
  local idx="$1"
  local proj_rel home_abs
  proj_rel="$(agent_field "$idx" 2)"
  home_abs="$(agent_field "$idx" 3)"

  case "$SCOPE_KIND" in
    home)
      [[ -n "$home_abs" ]] || { printf ''; return; }
      printf '%s' "${home_abs//__HOME__/$HOME}"
      ;;
    project|custom)
      printf '%s/%s' "$SCOPE_PATH" "$proj_rel"
      ;;
    *) die "internal: unknown SCOPE_KIND=$SCOPE_KIND" ;;
  esac
}

create_symlink_or_junction() {
  # Cross-platform link from $1 (existing source dir) to $2 (target path).
  # Returns 0 on success, non-zero on failure.
  local source="$1" target="$2"

  if ln -sfn "$source" "$target" 2>/dev/null; then
    return 0
  fi

  # Native-Windows fallback: directory junction. No admin or Developer Mode needed.
  local os; os="$(uname -s)"
  case "$os" in
    MINGW*|MSYS*|CYGWIN*)
      local win_source win_target
      win_source="$(cygpath -w "$source" 2>/dev/null || printf '%s' "$source")"
      win_target="$(cygpath -w "$target" 2>/dev/null || printf '%s' "$target")"
      # /J = junction (directories, same drive, no admin)
      cmd //c mklink //J "$win_target" "$win_source" >/dev/null 2>&1
      return $?
      ;;
  esac
  return 1
}

install_agent_symlink() {
  local idx="$1"
  local display target action
  display="$(agent_field "$idx" 4)"
  target="$(resolve_target_for_agent "$idx")"

  if [[ -z "$target" ]]; then
    warn "$display has no user-global path; skipping (use project scope instead)"
    return
  fi

  # No-op if the target already points at this checkout (idempotent install).
  if [[ -e "$target" ]] && [[ "$(realpath -- "$target" 2>/dev/null)" == "$(realpath -- "$SCRIPT_DIR" 2>/dev/null)" ]]; then
    ok "$display → $target (already linked)"
    return
  fi

  mkdir -p "$(dirname "$target")"

  if [[ -L "$target" || -e "$target" ]]; then
    if [[ -n "$CONFLICT_MODE" ]]; then
      action="$CONFLICT_MODE"
    else
      printf '\n'
      if [[ -L "$target" ]]; then
        warn "$target is a symlink to $(readlink -- "$target")"
      else
        warn "$target exists (not a symlink)"
      fi
      while true; do
        local choice=""
        read -rp "[s]kip / [o]verwrite > " choice </dev/tty
        case "$choice" in
          s|S) action=skip; break ;;
          o|O) action=overwrite; break ;;
        esac
      done
    fi
    case "$action" in
      skip)
        note "  Skipped $target ($display)"
        return ;;
      overwrite|append)
        rm -rf -- "$target"
        ;;
      *) die "unexpected conflict action: $action" ;;
    esac
  fi

  if create_symlink_or_junction "$SCRIPT_DIR" "$target"; then
    ok "$display → $target"
  else
    warn "Could not create link at $target. Clone senor directly to that path, or"
    note "  copy this checkout there manually."
  fi
}

install_agent() {
  local name="$1"
  local idx
  idx="$(agent_index_by_name "$name")" || die "unknown agent: $name"

  local template_basename
  template_basename="$(agent_field "$idx" 1)"

  if [[ -z "$template_basename" ]]; then
    install_agent_symlink "$idx"
    return
  fi

  local template_file display target content action
  template_file="$TEMPLATES_DIR/$template_basename"
  display="$(agent_field "$idx" 4)"
  target="$(resolve_target_for_agent "$idx")"

  if [[ -z "$target" ]]; then
    warn "$display has no user-global file path; skipping (use project scope instead)"
    return
  fi

  [[ -f "$template_file" ]] || die "missing template: $template_file"

  content="$(sed "s|__SENOR_SKILL__|$SENOR_SKILL|g" "$template_file")"

  mkdir -p "$(dirname "$target")"

  if [[ -e "$target" ]]; then
    # If the file is already exactly what we'd write, no real conflict —
    # skip silently. (Bash $(...) strips trailing newlines, so comparing
    # the captured value against $content correctly matches a file written
    # by a previous run.)
    local existing
    existing="$(cat "$target")"
    if [[ "$existing" == "$content" ]]; then
      note "  Up to date: $target ($display)"
      return
    fi

    if [[ -n "$CONFLICT_MODE" ]]; then
      action="$CONFLICT_MODE"
    else
      prompt_conflict "$target" "$content"
      action="$CONFLICT_RESULT"
    fi
    case "$action" in
      skip)
        note "  Skipped $target ($display)"
        return ;;
      overwrite)
        printf '%s\n' "$content" > "$target" ;;
      append)
        {
          printf '\n<!-- senor pointer -->\n'
          printf '%s\n' "$content"
        } >> "$target"
        ;;
      *) die "unexpected conflict action: $action" ;;
    esac
  else
    printf '%s\n' "$content" > "$target"
  fi
  ok "$display → $target"
}

# ---- Auto-update --------------------------------------------------------

setup_autoupdate() {
  local update_path="$SCRIPT_DIR/update"
  local frequency="${UPDATE_FREQUENCY:-weekly}"
  local os; os="$(uname -s)"

  # Cron schedule fields and human-readable description
  local cron_schedule schtasks_args human
  case "$frequency" in
    daily)
      cron_schedule="0 3 * * *"
      schtasks_args="//SC DAILY //ST 03:00"
      human="3am daily"
      ;;
    weekly)
      cron_schedule="0 3 * * 0"  # Sunday 3am
      schtasks_args="//SC WEEKLY //D SUN //ST 03:00"
      human="3am Sunday (weekly)"
      ;;
    *)
      if [[ "$frequency" =~ ^[0-9]+$ ]] && [[ "$frequency" -gt 0 ]]; then
        # Cron's `*/N` resets at month boundaries (Jan 31 → Feb 1 is one tick),
        # but it's good enough for practical N. schtasks /MO N is exact.
        cron_schedule="0 3 */$frequency * *"
        schtasks_args="//SC DAILY //MO $frequency //ST 03:00"
        if [[ "$frequency" -eq 1 ]]; then
          human="3am every day"
        else
          human="3am every $frequency days"
        fi
      else
        die "internal: invalid frequency $frequency"
      fi
      ;;
  esac

  case "$os" in
    Darwin|Linux)
      local entry="$cron_schedule $update_path >/dev/null 2>&1 # senor-update"
      local existing=""
      existing="$(crontab -l 2>/dev/null | grep -v '# senor-update' || true)"
      if [[ -n "$existing" ]]; then
        printf '%s\n%s\n' "$existing" "$entry" | crontab -
      else
        printf '%s\n' "$entry" | crontab -
      fi
      ok "Cron entry installed ($human)."
      note "  Remove with: crontab -l | grep -v 'senor-update' | crontab -"
      ;;
    MINGW*|MSYS*|CYGWIN*)
      local bash_path
      bash_path="$(command -v bash || true)"
      [[ -n "$bash_path" ]] || { warn "bash not on PATH; skipping auto-update setup"; return; }

      # Convert /c/Users/... to C:\Users\... for schtasks
      local win_update win_bash
      win_update="$(cygpath -w "$update_path" 2>/dev/null || printf '%s' "$update_path")"
      win_bash="$(cygpath -w "$bash_path" 2>/dev/null || printf '%s' "$bash_path")"

      local tr_value="\"$win_bash\" --login -i -- \"$win_update\""

      # shellcheck disable=SC2086  # we want $schtasks_args word-split
      if schtasks //Create //TN senor-update //TR "$tr_value" $schtasks_args //F >/dev/null 2>&1 \
         || schtasks /Create /TN senor-update /TR "$tr_value" ${schtasks_args//\/\//\/} /F >/dev/null 2>&1; then
        ok "Task Scheduler entry installed ($human)."
        note "  Remove with: schtasks /Delete /TN senor-update /F"
      else
        warn "Could not install Task Scheduler entry. Run manually:"
        printf '    schtasks /Create /TN senor-update /TR %q %s /F\n' "$tr_value" "${schtasks_args//\/\//\/}"
      fi
      ;;
    *)
      warn "Unknown OS ($os); skipping auto-update setup."
      note "  Run ./update manually when you want to refresh."
      ;;
  esac
}

# ---- State persistence --------------------------------------------------

save_state() {
  mkdir -p "$STATE_DIR"
  {
    printf 'SENOR_REPO=%q\n' "$SCRIPT_DIR"
    printf 'SCOPE_KIND=%q\n' "$SCOPE_KIND"
    printf 'SCOPE_PATH=%q\n' "$SCOPE_PATH"
    printf 'AGENTS=%q\n' "$SELECTED_AGENTS"
    printf 'AUTO_UPDATE=%q\n' "$AUTO_UPDATE"
  } > "$STATE_FILE"
  note "State saved to $STATE_FILE"
}

# ---- Main ---------------------------------------------------------------

main() {
  parse_flags "$@"

  print_banner

  # Sanity: templates dir exists
  [[ -d "$TEMPLATES_DIR" ]] || die "templates dir not found: $TEMPLATES_DIR"

  # Agents — pre-load previous install so multiselect can mark them
  load_prev_agents
  if [[ -z "$SELECTED_AGENTS" ]]; then
    multiselect
  fi
  if [[ -z "$SELECTED_AGENTS" ]]; then
    warn "No agents selected. Nothing to do."
    exit 0
  fi

  # Validate names
  IFS=',' read -ra _agent_list <<< "$SELECTED_AGENTS"
  for a in "${_agent_list[@]}"; do
    agent_index_by_name "$a" >/dev/null || die "unknown agent: $a"
  done

  # Scope
  if [[ -z "$SCOPE_KIND" ]]; then
    prompt_scope
  fi
  case "$SCOPE_KIND" in
    project|custom) [[ -d "$SCOPE_PATH" ]] || die "target dir does not exist: $SCOPE_PATH" ;;
    home) ;;
    *) die "no scope set" ;;
  esac

  if [[ "$SCOPE_KIND" == home ]]; then
    printf '\n%sScope:%s user-global\n' "$BOLD" "$RESET"
  else
    printf '\n%sScope:%s %s (%s)\n' "$BOLD" "$RESET" "$SCOPE_KIND" "$SCOPE_PATH"
  fi
  printf '%sAgents:%s %s\n\n' "$BOLD" "$RESET" "$SELECTED_AGENTS"

  for a in "${_agent_list[@]}"; do
    install_agent "$a"
  done

  # Auto-update
  if [[ -z "$AUTO_UPDATE" ]]; then
    prompt_auto_update
  fi
  if [[ "$AUTO_UPDATE" == "yes" ]]; then
    if [[ -z "$UPDATE_FREQUENCY" ]]; then
      prompt_frequency
    fi
    setup_autoupdate
  fi

  save_state
  printf '\n'
  ok "Done."
}

main "$@"
