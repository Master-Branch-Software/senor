#!/usr/bin/env bash
# Señor updater — git pull + non-interactive reinstall using saved state.
# Run by cron / Task Scheduler when auto-update is enabled, or manually.

set -euo pipefail

STATE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/senor/state"
LOG_PREFIX="[senor-update]"

log() { printf '%s %s\n' "$LOG_PREFIX" "$*"; }
fail() { printf '%s ERROR: %s\n' "$LOG_PREFIX" "$*" >&2; exit 1; }

[[ -f "$STATE_FILE" ]] || fail "no state file at $STATE_FILE; run ./install first"

# shellcheck source=/dev/null
. "$STATE_FILE"

: "${SENOR_REPO:?$LOG_PREFIX SENOR_REPO not set in state}"
: "${SCOPE_KIND:?$LOG_PREFIX SCOPE_KIND not set in state}"
: "${AGENTS:?$LOG_PREFIX AGENTS not set in state}"

[[ -d "$SENOR_REPO/.git" ]] || fail "senor repo missing or not a git checkout: $SENOR_REPO"

# Refresh the repo. --ff-only avoids creating merge commits in a non-interactive
# context. If the pull fails (network, merge conflict, divergent history), log
# and continue with whatever's currently checked out — better stale rules than
# a broken update that prevents the reinstall.
old_head="$(git -C "$SENOR_REPO" rev-parse HEAD)"
if git -C "$SENOR_REPO" pull --quiet --ff-only 2>/dev/null; then
  new_head="$(git -C "$SENOR_REPO" rev-parse HEAD)"
  if [[ "$old_head" != "$new_head" ]]; then
    log "pulled $(git -C "$SENOR_REPO" rev-list --count "$old_head..$new_head") commits"
  else
    log "already up to date"
  fi
else
  log "git pull failed (offline, conflict, or no upstream); reinstalling at current revision"
fi

scope_arg=""
case "$SCOPE_KIND" in
  project|custom) scope_arg="$SCOPE_PATH" ;;
  home)           scope_arg="home" ;;
  *)              fail "unknown SCOPE_KIND in state: $SCOPE_KIND" ;;
esac

"$SENOR_REPO/install" \
  --agents "$AGENTS" \
  --scope "$scope_arg" \
  --conflict overwrite \
  --no-auto-update
