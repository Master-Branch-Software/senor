#!/usr/bin/env bash
# new-domain — scaffold a new skill domain directory
# Usage: ./scripts/new-domain <domain-name>
# Example: ./scripts/new-domain python

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <domain-name>" >&2
  exit 1
fi

DOMAIN="$1"
ROOT="$(git rev-parse --show-toplevel)"
DIR="$ROOT/$DOMAIN"

if [[ -d "$DIR" ]]; then
  echo "Error: $DIR already exists." >&2
  exit 1
fi

mkdir -p "$DIR/references"

cat > "$DIR/AGENTS.md" << TEMPLATE
---
name: $DOMAIN
description: |
  Multi-sentence trigger description. Specific scope, common task verbs,
  and "even if the user does not say X explicitly" disambiguators.
  Used by skill-loading systems to score relevance — write for that
  scoring, not for human readers.
---

# ${DOMAIN^} Guide

General operating principles live in \`SKILL.md\` at the repository root. Read it first.

## Non-negotiables

- [absolute minimum, one rule per bullet]

## Task-to-chapter map

| Task | Primary | Also consider |
| --- | --- | --- |
| [task] | \`NN-topic.md\` | \`NN-topic.md\` |

## Domain checklists

Run before submitting:

- [item referencing a specific section: \`references/NN-topic.md\` § Section]

## Running order for [task type]

1. [stage] — [artifact]. [What to produce and confirm.]

## Skill connections

- [related skill or path] → [when to reach for it]

## Status

In progress. Chapter files live in \`$DOMAIN/references/\` following the
\`NN-topic.md\` convention. See \`CONTRIBUTING.md\` for entry-point structure,
chapter structure, sources sidecar structure, and routing edits.
TEMPLATE

echo "Created $DIR/AGENTS.md"
echo "Next:"
echo "  1. Fill AGENTS.md per CONTRIBUTING.md § Domain entry-point structure."
echo "  2. Add chapter files to $DIR/references/ (NN-topic.md + NN-topic.sources.md)."
echo "  3. Wire routing per CONTRIBUTING.md § Routing edits (SKILL.md, AGENTS.md, CONTRIBUTING.md)."
