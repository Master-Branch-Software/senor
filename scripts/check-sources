#!/usr/bin/env bash
# check-sources — verify every chapter topic.md has a matching topic.sources.md
# Usage: ./scripts/check-sources [domain]
# Example: ./scripts/check-sources front-end
#          ./scripts/check-sources          (checks all domains)

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
FAIL=0

check_domain() {
  local domain="$1"
  local dir="$ROOT/$domain"

  [[ -d "$dir" ]] || return

  while IFS= read -r -d '' chapter; do
    base="${chapter%.md}"
    sources="${base}.sources.md"
    if [[ ! -f "$sources" ]]; then
      echo "MISSING sources: ${sources#"$ROOT/"}"
      FAIL=1
    fi
  done < <(find "$dir" -maxdepth 1 -type f -name '*.md' \
              -not -name '*.sources.md' \
              -not -name 'AGENTS.md' \
              -not -name 'inspiration-gallery.md' \
              -print0 | sort -z)
}

if [[ $# -ge 1 ]]; then
  check_domain "$1"
else
  for domain in "$ROOT"/*/; do
    check_domain "$(basename "$domain")"
  done
fi

if [[ $FAIL -eq 0 ]]; then
  echo "All chapter files have matching sources files."
else
  echo ""
  echo "Fix: create the missing *.sources.md files per AGENTS.md rule 2."
  exit 1
fi
